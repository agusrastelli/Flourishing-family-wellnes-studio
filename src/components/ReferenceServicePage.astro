---
import DraftReferenceLayout from '../layouts/DraftReferenceLayout.astro';
import { servicePageShared } from '../data/services';
import { bookingUrl } from '../data/site';

interface ProgramLink {
  title: string;
  label: string;
  href: string;
}

interface Highlight {
  title: string;
  text: string;
}

interface Props {
  title: string;
  number: string;
  summary: string;
  image: string;
  imageAlt: string;
  current?: string;
  heroSize?: string;
  heroLineHeight?: string;
  highlightTitleSize?: string;
  leftEyebrow?: string;
  leftTitle: string;
  leftText: string;
  rightEyebrow?: string;
  rightTitle: string;
  rightText: string;
  highlightsEyebrow: string;
  highlightsTitle: string;
  highlights: Highlight[];
  note?: string;
  planTitle: string;
  programLinks: ProgramLink[];
}

const {
  title,
  number,
  summary,
  image,
  imageAlt,
  current = servicePageShared.current,
  heroSize = servicePageShared.defaultHeroSize,
  heroLineHeight = '1.04',
  highlightTitleSize = '20px',
  leftEyebrow = servicePageShared.defaultLeftEyebrow,
  leftTitle,
  leftText,
  rightEyebrow = servicePageShared.defaultRightEyebrow,
  rightTitle,
  rightText,
  highlightsEyebrow,
  highlightsTitle,
  highlights,
  note,
  planTitle,
  programLinks,
} = Astro.props;
---

<DraftReferenceLayout title={title} description={summary} current={current}>
  <section class="r-hero r-sect" style="max-width:1220px; margin:0 auto; padding:64px 32px 72px; display:grid; grid-template-columns:1.05fr .95fr; gap:64px; align-items:center;">
    <div>
      <div style="font-size:13px; margin-bottom:26px; color:#194247; opacity:.7;"><a href={servicePageShared.breadcrumbHref} style="color:#608F84; text-decoration:none; font-weight:600;">{servicePageShared.breadcrumbLabel}</a> <span style="opacity:.5;">/</span> {title}</div>
      <div style="display:inline-flex; align-items:center; gap:9px; font-size:12.5px; font-weight:600; letter-spacing:.16em; text-transform:uppercase; color:#608F84; margin-bottom:22px;">
        <span style="width:22px; height:1.5px; background:#608F84; display:inline-block;"></span>
        Service {number}
      </div>
      <h1 style={`font-family:'Fraunces',serif; font-weight:400; font-size:${heroSize}; line-height:${heroLineHeight}; letter-spacing:-.02em; color:#483E5E; margin:0 0 24px;`}>{title}</h1>
      <p style="font-size:20px; line-height:1.62; color:#194247; max-width:31em; margin:0 0 34px; opacity:.92;" set:html={summary}></p>
      <div style="display:flex; align-items:center; gap:24px; flex-wrap:wrap;">
        <a class="h-btn-primary" href={bookingUrl} style="text-decoration:none; background:#EBA040; color:#483E5E; font-weight:700; font-size:17px; padding:18px 36px; border-radius:999px; box-shadow:0 6px 22px rgba(235,160,64,.32);">Book a visit</a>
        <a class="h-link-underline" href="/2patient-resources/#pricing" style="text-decoration:none; color:#483E5E; font-weight:600; font-size:16px; border-bottom:2px solid rgba(72,62,94,.25); padding-bottom:3px;">See pricing&nbsp;→</a>
      </div>
    </div>
    <div style="position:relative; aspect-ratio:4/5; border-radius:6px; overflow:hidden; background:#ece0d6; box-shadow:0 30px 60px -28px rgba(72,62,94,.4);">
      <img src={image} alt={imageAlt} style="position:absolute; inset:0; width:100%; height:100%; object-fit:cover; display:block;" />
    </div>
  </section>

  <section class="r-sect r-pad-lg" style="background:#E2DCE2; padding:88px 32px;">
    <div style="max-width:1000px; margin:0 auto;">
      <div class="r-grid2" style="display:grid; grid-template-columns:1fr 1fr; gap:48px;">
        <div>
          <div style="font-size:12.5px; font-weight:600; letter-spacing:.16em; text-transform:uppercase; color:#608F84; margin-bottom:16px;">{leftEyebrow}</div>
          <h2 style="font-family:'Fraunces',serif; font-weight:400; font-size:clamp(28px,3.4vw,40px); line-height:1.12; color:#483E5E; margin:0 0 18px;">{leftTitle}</h2>
          <p style="font-size:17px; line-height:1.62; color:#194247; opacity:.9; margin:0;" set:html={leftText}></p>
        </div>
        <div>
          <div style="font-size:12.5px; font-weight:600; letter-spacing:.16em; text-transform:uppercase; color:#608F84; margin-bottom:16px;">{rightEyebrow}</div>
          <h2 style="font-family:'Fraunces',serif; font-weight:400; font-size:clamp(28px,3.4vw,40px); line-height:1.12; color:#483E5E; margin:0 0 18px;">{rightTitle}</h2>
          <p style="font-size:17px; line-height:1.62; color:#194247; opacity:.9; margin:0;" set:html={rightText}></p>
        </div>
      </div>
    </div>
  </section>

  <section class="r-sect r-pad-lg" style="max-width:1220px; margin:0 auto; padding:96px 32px;">
    <div style="max-width:34em; margin-bottom:44px;">
      <div style="font-size:12.5px; font-weight:600; letter-spacing:.16em; text-transform:uppercase; color:#608F84; margin-bottom:18px;">{highlightsEyebrow}</div>
      <h2 style="font-family:'Fraunces',serif; font-weight:400; font-size:clamp(32px,4.2vw,52px); line-height:1.08; letter-spacing:-.015em; color:#483E5E; margin:0;">{highlightsTitle}</h2>
    </div>
    <div class="r-tech" style="display:grid; grid-template-columns:repeat(4,1fr); gap:20px;">
      {highlights.map((item) => (
        <div style="background:#FCF0DD; border:1px solid rgba(72,62,94,.12); border-radius:10px; padding:30px 26px; box-shadow:0 8px 26px -20px rgba(72,62,94,.4);">
          <div style={`font-family:'Fraunces',serif; font-size:${highlightTitleSize}; color:#483E5E; margin-bottom:10px;`}>{item.title}</div>
          <p style="font-size:15px; line-height:1.55; color:#194247; opacity:.85; margin:0;" set:html={item.text}></p>
        </div>
      ))}
    </div>
    {note && (
      <div style="margin-top:30px; padding:22px 26px; background:rgba(96,143,132,.12); border-radius:8px; display:flex; gap:14px; align-items:center; max-width:52em;">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#608F84" stroke-width="1.6" style="flex:none;"><path d="M12 3l7 4v5c0 4-3 7-7 9-4-2-7-5-7-9V7l7-4z"></path><path d="M9 12l2 2 4-4"></path></svg>
        <span style="font-size:15px; line-height:1.55; color:#194247;" set:html={note}></span>
      </div>
    )}
  </section>

  <section class="r-sect r-pad-lg" style="background:#483E5E; color:#FCF0DD; padding:88px 32px;">
    <div style="max-width:1000px; margin:0 auto;">
      <div style="max-width:34em; margin-bottom:40px;">
        <div style="font-size:12.5px; font-weight:600; letter-spacing:.16em; text-transform:uppercase; color:#EBA040; margin-bottom:16px;">{servicePageShared.relatedEyebrow}</div>
        <h2 style="font-family:'Fraunces',serif; font-weight:400; font-size:clamp(28px,3.6vw,44px); line-height:1.1; color:#FCF0DD; margin:0;">{planTitle}</h2>
      </div>
      <div class="r-grid2" style="display:grid; grid-template-columns:repeat(3,1fr); gap:16px;">
        {programLinks.map((link) => (
          <a class="h-service-program-link" href={link.href} style="text-decoration:none; background:rgba(252,240,221,.06); border:1px solid rgba(252,240,221,.14); border-radius:10px; padding:24px 24px; display:block;">
            <div style="font-family:'Fraunces',serif; font-size:19px; color:#FCF0DD; margin-bottom:6px;">{link.title}</div>
            <div style="font-size:14px; color:#EBA040; font-weight:600;">{link.label}&nbsp;→</div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="r-sect r-pad-lg" style="max-width:1220px; margin:0 auto; padding:96px 32px; text-align:center;">
    <h2 style="font-family:'Fraunces',serif; font-weight:400; font-size:clamp(32px,4.4vw,54px); line-height:1.08; letter-spacing:-.015em; color:#483E5E; margin:0 0 24px; max-width:16em; margin-left:auto; margin-right:auto;">{servicePageShared.finalTitle}</h2>
    <p style="font-size:18px; line-height:1.62; color:#194247; opacity:.9; max-width:30em; margin:0 auto 34px;">{servicePageShared.finalText}</p>
    <div style="display:flex; gap:18px; justify-content:center; flex-wrap:wrap;">
      <a class="h-btn-primary" href={bookingUrl} style="text-decoration:none; background:#EBA040; color:#483E5E; font-weight:700; font-size:17px; padding:18px 40px; border-radius:999px; display:inline-block; box-shadow:0 6px 22px rgba(235,160,64,.32);">{servicePageShared.finalPrimaryLabel}</a>
      <a class="h-link-underline" href={servicePageShared.finalSecondaryHref} style="text-decoration:none; color:#483E5E; font-weight:600; font-size:16px; border-bottom:2px solid rgba(72,62,94,.25); padding-bottom:3px; align-self:center;">{servicePageShared.finalSecondaryLabel}&nbsp;→</a>
    </div>
  </section>
</DraftReferenceLayout>
