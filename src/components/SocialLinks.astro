---
import { socialLinks } from '../data/site';
---

<nav class="i-social-links" aria-label="Social media links">
  {socialLinks.map((link) => (
    <a href={link.href} aria-label={`Flourishing Family on ${link.label}`} target="_blank" rel="noopener noreferrer">
      {link.icon === 'facebook' && (
        <svg viewBox="0 0 24 24" aria-hidden="true">
          <path d="M14.1 8.1V6.4c0-.8.2-1.3 1.3-1.3h1.7V2.2c-.3 0-1.4-.1-2.6-.1-2.6 0-4.4 1.6-4.4 4.5v1.5H7.2v3.3h2.9v8.5h3.5v-8.5h2.9l.4-3.3h-2.8z" />
        </svg>
      )}
      {link.icon === 'instagram' && (
        <svg viewBox="0 0 24 24" aria-hidden="true">
          <path d="M7.4 2.8h9.2c2.6 0 4.6 2 4.6 4.6v9.2c0 2.6-2 4.6-4.6 4.6H7.4c-2.6 0-4.6-2-4.6-4.6V7.4c0-2.6 2-4.6 4.6-4.6zm0 2A2.6 2.6 0 0 0 4.8 7.4v9.2a2.6 2.6 0 0 0 2.6 2.6h9.2a2.6 2.6 0 0 0 2.6-2.6V7.4a2.6 2.6 0 0 0-2.6-2.6H7.4zm4.6 3.4a3.8 3.8 0 1 1 0 7.6 3.8 3.8 0 0 1 0-7.6zm0 2a1.8 1.8 0 1 0 0 3.6 1.8 1.8 0 0 0 0-3.6zm4.1-2.8a1 1 0 1 1 2 0 1 1 0 0 1-2 0z" />
        </svg>
      )}
      {link.icon === 'yelp' && (
        <svg viewBox="0 0 24 24" aria-hidden="true">
          <path d="M12.2 2.2c1.1.1 2 .6 2.4 1.3.2.3.2.7 0 1l-2.2 5.3c-.2.5-.9.5-1.1 0L9.1 4.5c-.2-.4-.1-.8.2-1.1.6-.7 1.7-1.1 2.9-1.2zm6 5.7c.6.8.8 1.8.5 2.6-.1.4-.4.6-.8.7l-4.9.9c-.5.1-.8-.5-.5-.9l3.1-3.8c.2-.3.6-.5 1-.4.6.1 1.2.4 1.6.9zm-12.3.2c.7-.7 1.7-1 2.5-.9.4.1.7.3.9.6l2.1 3.3c.3.4-.1.9-.6.8l-4.6-1.2c-.4-.1-.7-.4-.8-.8-.1-.6.1-1.3.5-1.8zm12.4 7c.2.9-.1 1.9-.8 2.5-.3.3-.7.3-1.1.2l-3.7-1.8c-.5-.2-.4-.9.1-1l4-.9c.4-.1.8.1 1 .4.3.2.4.4.5.6zm-8.1.3c.5 0 .7.7.3 1l-3.2 2.6c-.3.2-.7.3-1.1.1-.8-.4-1.4-1.2-1.5-2.2 0-.4.1-.8.4-1l3.7-2.1c.5-.2.9.2.8.7l-.1.1.7.8z" />
        </svg>
      )}
      {link.icon === 'nextdoor' && (
        <svg viewBox="0 0 24 24" aria-hidden="true">
          <path d="M2.5 3.5c-.6 0-1 .4-1 1v3C1.5 10 3.5 12 6 12h.5v7.5c0 .6.4 1 1 1h4c.6 0 1-.4 1-1v-8c0-1.1.9-2 2-2s2 .9 2 2v8c0 .6.4 1 1 1h4c.6 0 1-.4 1-1v-8c0-4.4-3.6-8-8-8-2.7 0-5.2 1.4-6.6 3.5-.2 0-.4-.2-.4-.5v-2c0-.6-.4-1-1-1h-5z" />
        </svg>
      )}
      <span>{link.label}</span>
    </a>
  ))}
</nav>
