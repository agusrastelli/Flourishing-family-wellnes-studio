---
import DraftReferenceLayout from '../layouts/DraftReferenceLayout.astro';
import ProgramCards from './ProgramCards.astro';
import { bookingUrl } from '../data/site';

interface IncludeItem {
  component: string;
  value: string;
  valueStyle?: 'price' | 'included' | 'italic';
}

interface CardItem {
  text: string;
}

interface StepItem {
  title: string;
  text: string;
  badge?: string;
  highlighted?: boolean;
}

interface FaqItem {
  question: string;
  answer: string;
}

interface StageItem {
  label: string;
  active?: boolean;
}

interface ProgramPageData {
  slug: string;
  routeSlug: string;
  order: number;
  eyebrow: string;
  programName: string;
  title: string;
  summary: string;
  image: string;
  imageAlt: string;
  heroSize?: string;
  ctaLabel: string;
  secondaryCtaLabel: string;
  secondaryCtaHref: string;
  metaLine: string;
  isThisTitle: string;
  isThisText?: string;
  isThisYou: CardItem[];
  before: string;
  approachEyebrow: string;
  approachImage?: string;
  approachImageAlt?: string;
  approachBg?: string;
  approachTitle: string;
  approachParagraphs: string[];
  approachNote: string;
  includedTitle: string;
  includes: IncludeItem[];
  totalLabel: string;
  totalValue: string;
  howEyebrow: string;
  howTitle: string;
  howText?: string;
  roadmapVariant?: 'steps' | 'trimester';
  roadmap: StepItem[];
  roadmapNote?: string;
  trustTitle: string;
  trust: string[];
  investmentVariant?: 'price' | 'packages';
  investmentPrice?: string;
  investmentSub?: string;
  investmentLine?: string;
  investmentTitle?: string;
  investmentText?: string;
  investmentPills?: string[];
  perspectiveEyebrow?: string;
  perspective: string;
  investmentFootnote: string;
  promiseTitle: string;
  promiseText: string;
  faqs: FaqItem[];
  bookTitle: string;
  finalNote: string;
  stickyLabel: string;
  relatedStageLabel: string;
  relatedSummary: string;
  relatedStages: StageItem[];
}

type RelatedProgram = Pick<
  ProgramPageData,
  'slug' | 'routeSlug' | 'eyebrow' | 'title' | 'summary' | 'image' | 'imageAlt'
>;

interface Props {
  program: ProgramPageData;
  relatedPrograms?: RelatedProgram[];
  current?: string;
  linkMode?: 'draft' | 'public';
}

const { program, relatedPrograms = [], current = 'programs', linkMode = 'public' } = Astro.props;

const approachImage = program.approachImage ?? '/assets/opt/ila.jpg';
const approachImageAlt = program.approachImageAlt ?? 'A doctor working hands-on and unhurried with a patient';
const approachBg = program.approachBg ?? 'linear-gradient(155deg,#dde8e2,#ece0d6)';
const heroSize = program.heroSize ?? 'clamp(44px,6vw,84px)';
const roadmapVariant = program.roadmapVariant ?? 'steps';
const investmentVariant = program.investmentVariant ?? 'price';
const perspectiveEyebrow = program.perspectiveEyebrow ?? 'For perspective';
const approachSectionId = program.secondaryCtaHref?.startsWith('#') && program.secondaryCtaHref !== '#included'
  ? program.secondaryCtaHref.slice(1)
  : undefined;
---

<DraftReferenceLayout title={program.programName} description={program.summary} current={current}>
  <section id="top" class="r-hero r-sect" style="max-width:1220px; margin:0 auto; padding:74px 32px 88px; display:grid; grid-template-columns:1.05fr .95fr; gap:64px; align-items:center;">
    <div>
      <div style="display:inline-flex; align-items:center; gap:9px; font-size:12.5px; font-weight:600; letter-spacing:.16em; text-transform:uppercase; color:#608F84; margin-bottom:34px;">
        <span style="width:22px; height:1.5px; background:#608F84; display:inline-block;"></span>
        {program.programName}
      </div>
      <h1 set:html={program.title} style={`font-family:'Fraunces',serif; font-weight:400; font-size:${heroSize}; line-height:1.03; letter-spacing:-.02em; color:#483E5E; margin:0 0 26px;`}></h1>
      <p set:html={program.summary} style="font-size:20px; line-height:1.62; color:#194247; max-width:31em; margin:0 0 36px; opacity:.92;"></p>
      <div style="display:flex; align-items:center; gap:26px; flex-wrap:wrap;">
        <a class="h-btn-primary" href="#book" style="text-decoration:none; background:#EBA040; color:#483E5E; font-weight:700; font-size:17px; padding:18px 36px; border-radius:999px; box-shadow:0 6px 22px rgba(235,160,64,.32);">{program.ctaLabel}</a>
        <a class="h-link-underline" href={program.secondaryCtaHref} style="text-decoration:none; color:#483E5E; font-weight:600; font-size:16px; border-bottom:2px solid rgba(72,62,94,.25); padding-bottom:3px;">{program.secondaryCtaLabel}&nbsp;→</a>
      </div>
      <div set:html={program.metaLine} style="margin-top:38px; font-size:14.5px; color:#194247; opacity:.78; letter-spacing:.01em;"></div>
    </div>
    <div style="position:relative; aspect-ratio:4/5; border-radius:6px; overflow:hidden; background:#ece0d6; box-shadow:0 30px 60px -28px rgba(72,62,94,.4);">
      <img src={program.image} alt={program.imageAlt} style="position:absolute; inset:0; width:100%; height:100%; object-fit:cover; display:block;" />
    </div>
  </section>

  <section class="r-sect r-pad-lg" style="background:#E2DCE2; padding:96px 32px;">
    <div style="max-width:1220px; margin:0 auto;">
      <div style="max-width:36em; margin-bottom:52px;">
        <div style="font-size:12.5px; font-weight:600; letter-spacing:.16em; text-transform:uppercase; color:#608F84; margin-bottom:18px;">Is this you?</div>
        <h2 set:html={program.isThisTitle} style="font-family:'Fraunces',serif; font-weight:400; font-size:clamp(32px,4.2vw,52px); line-height:1.08; letter-spacing:-.015em; color:#483E5E; margin:0 0 20px;"></h2>
        {program.isThisText && <p set:html={program.isThisText} style="font-size:18px; line-height:1.6; color:#194247; opacity:.88; margin:0;"></p>}
      </div>
      <div class="r-grid3" style="display:grid; grid-template-columns:repeat(3,1fr); gap:24px; margin-bottom:44px;">
        {program.isThisYou.map((item, index) => (
          <div style="background:#FCF0DD; border-radius:8px; padding:32px 30px; box-shadow:0 8px 26px -18px rgba(72,62,94,.4);">
            <div style="font-family:'Fraunces',serif; font-size:34px; color:#EBA040; line-height:1; margin-bottom:16px;">0{index + 1}</div>
            <p set:html={item.text} style="font-size:16.5px; line-height:1.58; color:#194247; margin:0;"></p>
          </div>
        ))}
      </div>
      <p set:html={program.before} style="font-family:'Fraunces',serif; font-style:italic; font-weight:500; font-size:clamp(19px,2.3vw,26px); line-height:1.4; color:#483E5E; max-width:30em; margin:0;"></p>
    </div>
  </section>

  <section id={approachSectionId} class="r-split r-sect r-pad-lg" style="max-width:1220px; margin:0 auto; padding:100px 32px; display:grid; grid-template-columns:.92fr 1.08fr; gap:72px; align-items:center;">
    <div style={`position:relative; aspect-ratio:5/6; border-radius:6px; overflow:hidden; background:${approachBg}; box-shadow:0 28px 56px -30px rgba(72,62,94,.42);`}>
      <img src={approachImage} alt={approachImageAlt} style="position:absolute; inset:14px; width:calc(100% - 28px); height:calc(100% - 28px); object-fit:cover; border-radius:3px; display:block;" />
    </div>
    <div>
      <div style="font-size:12.5px; font-weight:600; letter-spacing:.16em; text-transform:uppercase; color:#608F84; margin-bottom:20px;">{program.approachEyebrow}</div>
      <h2 set:html={program.approachTitle} style="font-family:'Fraunces',serif; font-weight:400; font-size:clamp(30px,4vw,50px); line-height:1.1; letter-spacing:-.015em; color:#483E5E; margin:0 0 24px;"></h2>
      {program.approachParagraphs.map((paragraph, index) => (
        <p set:html={paragraph} style={`font-size:18.5px; line-height:1.66; color:#194247; max-width:32em; margin:0 0 ${index === program.approachParagraphs.length - 1 ? '30px' : '22px'}; opacity:.92;`}></p>
      ))}
      <div style="display:flex; gap:14px; align-items:center; padding:18px 22px; background:rgba(96,143,132,.12); border-radius:8px; max-width:34em;">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#608F84" stroke-width="1.6" style="flex:none;"><path d="M12 3l7 4v5c0 4-3 7-7 9-4-2-7-5-7-9V7l7-4z"></path><path d="M9 12l2 2 4-4"></path></svg>
        <span set:html={program.approachNote} style="font-size:15px; line-height:1.5; color:#194247;"></span>
      </div>
    </div>
  </section>

  <section id="included" class="r-sect r-pad-lg" style="background:#483E5E; color:#FCF0DD; padding:100px 32px;">
    <div style="max-width:1000px; margin:0 auto;">
      <div style="max-width:34em; margin-bottom:48px;">
        <div style="font-size:12.5px; font-weight:600; letter-spacing:.16em; text-transform:uppercase; color:#EBA040; margin-bottom:18px;">What’s included</div>
        <h2 set:html={program.includedTitle} style="font-family:'Fraunces',serif; font-weight:400; font-size:clamp(32px,4.2vw,52px); line-height:1.08; letter-spacing:-.015em; color:#FCF0DD; margin:0;"></h2>
      </div>
      <div style="background:rgba(252,240,221,.05); border:1px solid rgba(252,240,221,.16); border-radius:12px; padding:14px 34px;">
        {program.includes.map((item, index) => (
          <div class="r-stack-row" style={`display:flex; justify-content:space-between; gap:20px; align-items:baseline; padding:20px 0; ${index < program.includes.length - 1 ? 'border-bottom:1px solid rgba(252,240,221,.14);' : ''}`}>
            <div set:html={item.component} style="font-size:17px; line-height:1.5; color:#FCF0DD;"></div>
            <div
              set:html={item.value}
              style={item.valueStyle === 'included'
                ? 'font-size:15px; font-weight:600; letter-spacing:.06em; text-transform:uppercase; color:#608F84; white-space:nowrap;'
                : item.valueStyle === 'italic'
                  ? "font-family:'Fraunces',serif; font-style:italic; font-size:18px; color:#608F84; white-space:nowrap;"
                  : "font-family:'Fraunces',serif; font-size:20px; color:#EBA040; white-space:nowrap;"}
            ></div>
          </div>
        ))}
      </div>
      <div style="display:flex; justify-content:space-between; align-items:baseline; gap:20px; margin-top:22px; padding:0 34px;">
        <div style="font-size:15px; letter-spacing:.1em; text-transform:uppercase; font-weight:700; color:#c9c2d4;">{program.totalLabel}</div>
        <div set:html={program.totalValue} style="font-family:'Fraunces',serif; font-size:clamp(30px,4vw,44px); color:#EBA040; line-height:1;"></div>
      </div>
    </div>
  </section>

  <section class="r-sect r-pad-lg" style="max-width:1220px; margin:0 auto; padding:100px 32px;">
    <div style="max-width:36em; margin-bottom:52px;">
      <div style="font-size:12.5px; font-weight:600; letter-spacing:.16em; text-transform:uppercase; color:#608F84; margin-bottom:18px;">{program.howEyebrow}</div>
      <h2 set:html={program.howTitle} style="font-family:'Fraunces',serif; font-weight:400; font-size:clamp(32px,4.2vw,52px); line-height:1.08; letter-spacing:-.015em; color:#483E5E; margin:0 0 18px;"></h2>
      {program.howText && <p set:html={program.howText} style="font-size:18px; line-height:1.6; color:#194247; opacity:.88; margin:0;"></p>}
    </div>
    {roadmapVariant === 'trimester' ? (
      <div class="r-trimester" style="display:grid; grid-template-columns:repeat(3,1fr); gap:24px;">
        {program.roadmap.map((step) => (
          <div style={`background:#FCF0DD; border:${step.highlighted ? '1.5px solid #EBA040' : '1px solid rgba(72,62,94,.14)'}; border-radius:10px; padding:34px 30px; box-shadow:0 12px 32px -20px rgba(72,62,94,.4);`}>
            {step.badge && (
              <div style={`display:inline-block; font-size:12px; font-weight:700; letter-spacing:.1em; text-transform:uppercase; color:${step.highlighted ? '#483E5E' : '#608F84'}; background:${step.highlighted ? '#EBA040' : 'rgba(96,143,132,.14)'}; padding:5px 12px; border-radius:999px; margin-bottom:20px;`}>{step.badge}</div>
            )}
            <h3 set:html={step.title} style="font-family:'Fraunces',serif; font-weight:400; font-size:26px; color:#483E5E; margin:0 0 10px;"></h3>
            <p set:html={step.text} style="font-size:15.5px; line-height:1.58; color:#194247; opacity:.85; margin:0;"></p>
          </div>
        ))}
      </div>
    ) : (
      <div class="r-steps" style={`display:grid; grid-template-columns:repeat(${program.roadmap.length},1fr); gap:28px;`}>
        {program.roadmap.map((step, index) => (
          <div style={`border-top:2px solid ${index === 0 ? '#EBA040' : 'rgba(72,62,94,.2)'}; padding-top:22px;`}>
            <div style="font-family:'Fraunces',serif; font-size:15px; letter-spacing:.14em; color:#B7863E; font-weight:600; margin-bottom:16px;">STEP 0{index + 1}</div>
            <h3 set:html={step.title} style="font-family:'Fraunces',serif; font-weight:500; font-size:22px; color:#483E5E; margin:0 0 10px;"></h3>
            <p set:html={step.text} style="font-size:15.5px; line-height:1.58; color:#194247; opacity:.85; margin:0;"></p>
          </div>
        ))}
      </div>
    )}
    {program.roadmapNote && <p set:html={program.roadmapNote} style="font-size:14.5px; line-height:1.55; color:#194247; opacity:.72; margin:28px 0 0; text-align:center;"></p>}
  </section>

  <section class="r-invest r-sect r-pad-lg" style="background:#E2DCE2; padding:100px 32px; display:grid; grid-template-columns:1fr 1fr; gap:64px; max-width:1220px; margin:0 auto; align-items:start;">
    <div>
      <div style="font-size:12.5px; font-weight:600; letter-spacing:.16em; text-transform:uppercase; color:#608F84; margin-bottom:20px;">Why trust this</div>
      <h2 set:html={program.trustTitle} style="font-family:'Fraunces',serif; font-weight:400; font-size:clamp(30px,3.6vw,44px); line-height:1.1; letter-spacing:-.015em; color:#483E5E; margin:0 0 30px;"></h2>
      <div style="display:flex; flex-direction:column; gap:22px;">
        {program.trust.map((item) => (
          <div style="display:flex; gap:14px; align-items:flex-start;">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#608F84" stroke-width="1.8" style="flex:none; margin-top:2px;"><path d="M5 12l5 5 9-11"></path></svg>
            <p set:html={item} style="font-size:16.5px; line-height:1.55; color:#194247; margin:0;"></p>
          </div>
        ))}
      </div>
    </div>
    <div style="background:#FCF0DD; border-radius:12px; padding:40px 38px; box-shadow:0 20px 44px -24px rgba(72,62,94,.45);">
      <div style="font-size:12.5px; font-weight:600; letter-spacing:.16em; text-transform:uppercase; color:#608F84; margin-bottom:20px;">The investment</div>
      {investmentVariant === 'packages' ? (
        <>
          <div set:html={program.investmentTitle} style="font-family:'Fraunces',serif; font-size:clamp(30px,3.6vw,40px); color:#483E5E; line-height:1.15; margin-bottom:10px;"></div>
          <p set:html={program.investmentText} style="font-size:16px; line-height:1.55; color:#194247; opacity:.85; margin:0 0 22px;"></p>
          {program.investmentPills && (
            <div style="display:flex; flex-wrap:wrap; gap:10px; margin-bottom:22px;">
              {program.investmentPills.map((pill) => (
                <span style="font-size:13.5px; font-weight:600; color:#194247; background:rgba(96,143,132,.14); padding:8px 14px; border-radius:999px;">{pill}</span>
              ))}
            </div>
          )}
        </>
      ) : (
        <>
          <div style="display:flex; align-items:baseline; gap:14px; flex-wrap:wrap; margin-bottom:8px;">
            <div set:html={program.investmentPrice} style="font-family:'Fraunces',serif; font-size:clamp(44px,6vw,64px); color:#483E5E; line-height:1;"></div>
            <div set:html={program.investmentSub} style="font-size:16px; color:#194247; opacity:.8;"></div>
          </div>
          {program.investmentLine && <div set:html={program.investmentLine} style="font-size:16px; color:#194247; margin-bottom:26px;"></div>}
        </>
      )}
      <div style={`padding:22px 24px; background:rgba(96,143,132,.12); border-radius:8px; margin:${investmentVariant === 'packages' ? '0 0 20px' : '0 0 24px'};`}>
        <div style="font-size:13px; letter-spacing:.08em; text-transform:uppercase; font-weight:700; color:#608F84; margin-bottom:8px;">{perspectiveEyebrow}</div>
        <p set:html={program.perspective} style="font-size:16px; line-height:1.55; color:#194247; margin:0;"></p>
      </div>
      <p set:html={program.investmentFootnote} style="font-size:14.5px; line-height:1.55; color:#194247; opacity:.78; margin:0;"></p>
    </div>
  </section>

  <section class="r-sect r-pad-lg" style="background:#483E5E; padding:104px 32px;">
    <div style="max-width:820px; margin:0 auto; text-align:center;">
      <svg width="42" height="42" viewBox="0 0 24 24" fill="none" stroke="#EBA040" stroke-width="1.3" style="margin-bottom:28px;"><path d="M12 3l7 4v5c0 4-3 7-7 9-4-2-7-5-7-9V7l7-4z"></path><path d="M9 12l2 2 4-4"></path></svg>
      <div style="font-size:12.5px; font-weight:600; letter-spacing:.16em; text-transform:uppercase; color:#EBA040; margin-bottom:22px;">Our promise</div>
      <p set:html={program.promiseTitle} style="font-family:'Fraunces',serif; font-weight:400; font-size:clamp(24px,3.2vw,38px); line-height:1.32; letter-spacing:-.01em; color:#FCF0DD; margin:0 0 24px;"></p>
      <p set:html={program.promiseText} style="font-size:18px; line-height:1.68; color:#d6cfe0; max-width:34em; margin:0 auto;"></p>
    </div>
  </section>

  <section class="r-sect r-pad-lg" style="max-width:840px; margin:0 auto; padding:100px 32px;">
    <div style="margin-bottom:44px;">
      <div style="font-size:12.5px; font-weight:600; letter-spacing:.16em; text-transform:uppercase; color:#608F84; margin-bottom:18px;">The real questions</div>
      <h2 style="font-family:'Fraunces',serif; font-weight:400; font-size:clamp(32px,4.2vw,52px); line-height:1.08; letter-spacing:-.015em; color:#483E5E; margin:0;">Answered honestly.</h2>
    </div>
    <div style="display:flex; flex-direction:column; gap:0;">
      {program.faqs.map((item, index) => (
        <details class="r-faq" style={`border-top:1px solid rgba(72,62,94,.16); ${index === program.faqs.length - 1 ? 'border-bottom:1px solid rgba(72,62,94,.16);' : ''}`}>
          <summary style="list-style:none; cursor:pointer; display:flex; justify-content:space-between; align-items:center; gap:20px; padding:24px 0; font-family:'Fraunces',serif; font-size:clamp(19px,2.2vw,23px); color:#483E5E;">{item.question}<span class="r-faq-plus" style="flex:none; color:#EBA040; font-size:26px; line-height:1; transition:transform .2s;">+</span></summary>
          <p set:html={item.answer} style="font-size:16.5px; line-height:1.62; color:#194247; opacity:.9; margin:0 0 24px; max-width:52em;"></p>
        </details>
      ))}
    </div>
  </section>

  <section id="book" class="r-sect r-pad-lg" style="background:#483E5E; color:#FCF0DD; padding:104px 32px;">
    <div style="max-width:760px; margin:0 auto; text-align:center;">
      <h2 set:html={program.bookTitle} style="font-family:'Fraunces',serif; font-weight:400; font-size:clamp(36px,5vw,64px); line-height:1.05; letter-spacing:-.02em; margin:0 0 26px; color:#FCF0DD;"></h2>
      <p set:html={program.finalNote} style="font-size:18px; line-height:1.65; color:#d6cfe0; max-width:32em; margin:0 auto 38px;"></p>
      <a class="h-btn-primary h-btn-primary-strong" href={bookingUrl} style="text-decoration:none; background:#EBA040; color:#483E5E; font-weight:700; font-size:17px; padding:18px 40px; border-radius:999px; display:inline-block; box-shadow:0 6px 22px rgba(235,160,64,.32);">{program.ctaLabel}</a>
    </div>
  </section>

  <section class="r-sect r-pad-lg" style="max-width:1220px; margin:0 auto; padding:100px 32px;">
    <div style="text-align:center; margin-bottom:48px;">
      <div style="font-size:12.5px; font-weight:600; letter-spacing:.16em; text-transform:uppercase; color:#608F84; margin-bottom:20px;">One practice, every season</div>
      <div style="display:inline-flex; align-items:center; gap:16px; flex-wrap:wrap; justify-content:center; font-family:'Fraunces',serif; font-size:clamp(18px,2.4vw,26px); color:#483E5E;">
        {program.relatedStages.map((stage, index) => (
          <>
            <span style={stage.active ? 'color:#EBA040;' : ''}>{stage.label}</span>
            {index < program.relatedStages.length - 1 && (
              <svg class="r-arrow" width="30" height="12" viewBox="0 0 30 12" fill="none" stroke="#B7863E" stroke-width="1.5"><path d="M0 6h27M22 1l6 5-6 5"></path></svg>
            )}
          </>
        ))}
      </div>
    </div>
    <div style="margin-bottom:44px;">
      <ProgramCards items={relatedPrograms} columns={relatedPrograms.length === 2 ? 2 : 3} linkMode={linkMode} />
    </div>
    <!-- <div style="text-align:center; padding:36px; background:#E2DCE2; border-radius:12px;">
      <p style="font-size:17px; line-height:1.55; color:#194247; max-width:34em; margin:0 auto 22px;">Not sure which stage you’re in? Come tell us what’s going on. We’ll be straight with you about whether we can help and what it would take. No hard sell.</p>
      <a class="h-btn-primary" href="#book" style="text-decoration:none; background:#EBA040; color:#483E5E; font-weight:700; font-size:16px; padding:15px 32px; border-radius:999px; display:inline-block; box-shadow:0 6px 20px rgba(235,160,64,.3);">Start with a conversation</a>
    </div> -->
  </section>

  <a class="h-sticky" href="#book" style="position:fixed; bottom:24px; right:24px; z-index:60; background:#EBA040; color:#483E5E; font-weight:700; font-size:15px; padding:15px 26px; border-radius:999px; text-decoration:none; box-shadow:0 10px 30px -6px rgba(72,62,94,.5);">{program.stickyLabel}</a>
</DraftReferenceLayout>
