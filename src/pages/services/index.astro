---
import DraftReferenceLayout from '../../layouts/DraftReferenceLayout.astro';
import ProgramCards from '../../components/ProgramCards.astro';
import { services } from '../../data/services';
import { bookingUrl } from '../../data/site';

const serviceCards = services.map((service) => ({
  href: `/${service.routeSlug}/`,
  img: service.cardImage,
  tag: service.cardTag,
  title: service.title,
  blurb: service.cardBlurb,
}));

---

<DraftReferenceLayout title="Services" description="Five ways we care for your family." current="services">
  <section class="r-hero r-sect" style="max-width:1220px; margin:0 auto; padding:74px 32px 60px; display:grid; grid-template-columns:1.05fr .95fr; gap:64px; align-items:center;">
    <div>
      <div style="display:inline-flex; align-items:center; gap:9px; font-size:12.5px; font-weight:600; letter-spacing:.16em; text-transform:uppercase; color:#608F84; margin-bottom:34px;">
        <span style="width:22px; height:1.5px; background:#608F84; display:inline-block;"></span>
        Services
      </div>
      <h1 style="font-family:'Fraunces',serif; font-weight:400; font-size:clamp(44px,6vw,84px); line-height:1.03; letter-spacing:-.02em; color:#483E5E; margin:0 0 26px;">Five ways we care for your family.</h1>
      <p style="font-size:20px; line-height:1.62; color:#194247; max-width:31em; margin:0 0 36px; opacity:.92;">Chiropractic, acupuncture, and nutrition are the tools; your program decides how we use them. Choose a service to see exactly what it is: no jargon, no mystery.</p>
      <a class="h-btn-primary" href="#services" style="text-decoration:none; background:#EBA040; color:#483E5E; font-weight:700; font-size:17px; padding:18px 36px; border-radius:999px; box-shadow:0 6px 22px rgba(235,160,64,.32); display:inline-block;">Browse the services</a>
    </div>
    <div style="position:relative; aspect-ratio:4/5; border-radius:6px; overflow:hidden; background:#ece0d6; box-shadow:0 30px 60px -28px rgba(72,62,94,.4);">
      <img src="/assets/opt/ila.jpg" alt="Doctor adjusting a patient" style="position:absolute; inset:0; width:100%; height:100%; object-fit:cover; display:block;" />
    </div>
  </section>

  <section class="r-sect" style="background:#E2DCE2; padding:48px 32px;">
    <p style="max-width:760px; margin:0 auto; text-align:center; font-family:'Fraunces',serif; font-size:clamp(22px,2.8vw,32px); line-height:1.28; color:#483E5E;">These are not one-off, quick-fix visits. Each service is a piece of a plan a doctor builds around you.</p>
  </section>

  <section id="services" class="r-sect r-pad-lg" style="max-width:1220px; margin:0 auto; padding:88px 32px;">
    <div style="max-width:34em; margin-bottom:44px;">
      <div style="font-size:12.5px; font-weight:600; letter-spacing:.16em; text-transform:uppercase; color:#608F84; margin-bottom:18px;">Care options</div>
      <h2 style="font-family:'Fraunces',serif; font-weight:400; font-size:clamp(32px,4.2vw,52px); line-height:1.08; color:#483E5E; margin:0;">Each one has its own page.</h2>
    </div>
    <div class="r-cards" style="display:grid; grid-template-columns:repeat(3,1fr); gap:26px;">
      {serviceCards.map((card) => (
        <a href={card.href} style="text-decoration:none; display:flex; flex-direction:column; background:#FCF0DD; border-radius:8px; overflow:hidden; box-shadow:0 10px 30px -16px rgba(72,62,94,.32), 0 2px 6px rgba(72,62,94,.08);">
          <div style="aspect-ratio:3/2; background:linear-gradient(140deg,#dde8e2,#ece0d6); position:relative;">
            <img src={card.img} alt="" style="position:absolute; inset:14px; width:calc(100% - 28px); height:calc(100% - 28px); object-fit:cover; border-radius:3px; display:block;" />
          </div>
          <div style="padding:28px 28px 32px;">
            <div style="font-size:12px; font-weight:700; letter-spacing:.14em; text-transform:uppercase; color:#B7863E; margin-bottom:12px;">{card.tag}</div>
            <h3 style="font-family:'Fraunces',serif; font-weight:400; font-size:25px; line-height:1.2; color:#483E5E; margin:0 0 12px;">{card.title}</h3>
            <p style="font-size:15.5px; line-height:1.6; color:#194247; opacity:.85; margin:0 0 18px;">{card.blurb}</p>
            <span style="font-size:15px; font-weight:600; color:#608F84;">Explore&nbsp;→</span>
          </div>
        </a>
      ))}
    </div>
  </section>

  <section class="r-sect r-pad-lg" style="background:#E2DCE2; padding:88px 32px;">
    <div style="max-width:1220px; margin:0 auto;">
      <div style="max-width:38em; margin-bottom:36px;">
        <div style="font-size:12.5px; font-weight:600; letter-spacing:.16em; text-transform:uppercase; color:#608F84; margin-bottom:16px;">Programs</div>
        <h2 style="font-family:'Fraunces',serif; font-weight:400; font-size:clamp(30px,3.8vw,46px); line-height:1.1; color:#483E5E; margin:0 0 18px;">Looking for a full plan, not a single visit?</h2>
        <p style="font-size:17px; line-height:1.62; color:#194247; opacity:.9; margin:0;">Each program combines these services on a defined timeline, with one doctor and a clear guarantee.</p>
      </div>
      <ProgramCards />
    </div>
  </section>

  <section class="r-sect r-pad-lg" style="background:#483E5E; color:#FCF0DD; padding:100px 32px;">
    <div style="max-width:760px; margin:0 auto; text-align:center;">
      <h2 style="font-family:'Fraunces',serif; font-weight:400; font-size:clamp(34px,4.6vw,58px); line-height:1.08; color:#FCF0DD; margin:0 0 26px;">One practice. Every kind of care.</h2>
      <p style="font-size:18px; line-height:1.65; color:#d6cfe0; max-width:32em; margin:0 auto 38px;">Book a first visit one-on-one with a doctor, or start with a no-pressure conversation about what would actually help.</p>
      <div style="display:flex; gap:18px; justify-content:center; flex-wrap:wrap;">
        <a class="h-btn-primary" href={bookingUrl} style="text-decoration:none; background:#EBA040; color:#483E5E; font-weight:700; font-size:17px; padding:18px 40px; border-radius:999px; display:inline-block; box-shadow:0 6px 22px rgba(235,160,64,.32);">Book a visit</a>
        <a class="h-link-underline" href="/2contact/" style="text-decoration:none; color:#FCF0DD; font-weight:600; font-size:16px; border-bottom:2px solid rgba(252,240,221,.35); padding-bottom:3px; align-self:center;">Start with a conversation&nbsp;→</a>
      </div>
    </div>
  </section>
</DraftReferenceLayout>
