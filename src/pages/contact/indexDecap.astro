---
import DraftReferenceLayout from '../../layouts/DraftReferenceLayout.astro';
import { bookingUrl, contactInfo } from '../../data/site.ts';

const cards = [
  { title: contactInfo.phone, text: 'Mon, Wed, Thu, Fri, and Sat hours vary. Tuesday and Sunday are closed.', href: contactInfo.phoneHref, label: 'Call the studio' },
  { title: '68 Washington Street', text: 'Clark, NJ 07066. Just off the Parkway and easy to reach from across Union County.', href: contactInfo.mapsUrl, label: 'Open in Google Maps' },
];

const towns = ['Clark', 'Westfield', 'Cranford', 'Scotch Plains'];
---

<DraftReferenceLayout title="Contact" description="Contact Flourishing Family Wellness Studio." current="contact">
  <section class="r-contact r-sect" style="max-width:1220px; margin:0 auto; padding:74px 32px 88px; display:grid; grid-template-columns:1fr 1fr; gap:64px; align-items:start;">
    <div>
      <div style="display:inline-flex; align-items:center; gap:9px; font-size:12.5px; font-weight:600; letter-spacing:.16em; text-transform:uppercase; color:#608F84; margin-bottom:34px;">
        <span style="width:22px; height:1.5px; background:#608F84; display:inline-block;"></span>
        Contact
      </div>
      <h1 style="font-family:'Fraunces',serif; font-weight:400; font-size:clamp(44px,6vw,84px); line-height:1.03; letter-spacing:-.02em; color:#483E5E; margin:0 0 26px;">Ready when real life is.</h1>
      <p style="font-size:20px; line-height:1.62; color:#194247; max-width:31em; margin:0 0 36px; opacity:.92;">Early mornings, evenings, and Saturdays: hours that fit real life. Every first visit is one-on-one with a doctor.</p>
      <div style="display:flex; align-items:center; gap:20px; flex-wrap:wrap;">
        <a class="h-btn-primary" href={bookingUrl} style="text-decoration:none; background:#EBA040; color:#483E5E; font-weight:700; font-size:17px; padding:18px 36px; border-radius:999px; box-shadow:0 6px 22px rgba(235,160,64,.32);">Book your first visit</a>
        <a class="h-link-underline" href={contactInfo.phoneHref} style="text-decoration:none; color:#483E5E; font-weight:600; font-size:16px; border-bottom:2px solid rgba(72,62,94,.25); padding-bottom:3px;">Call {contactInfo.phone}</a>
      </div>
    </div>
    <div style="display:grid; gap:20px;">
      {cards.map((card) => (
        <a href={card.href} style="text-decoration:none; background:#FCF0DD; border-radius:10px; padding:30px 30px; box-shadow:0 10px 30px -16px rgba(72,62,94,.32), 0 2px 6px rgba(72,62,94,.08); border:1px solid rgba(72,62,94,.1); display:block;">
          <h2 style="font-family:'Fraunces',serif; font-weight:400; font-size:clamp(26px,3vw,36px); line-height:1.1; color:#483E5E; margin:0 0 12px;">{card.title}</h2>
          <p style="font-size:16px; line-height:1.58; color:#194247; opacity:.86; margin:0 0 18px;">{card.text}</p>
          <span style="font-size:15px; font-weight:700; color:#608F84;">{card.label}&nbsp;→</span>
        </a>
      ))}
    </div>
  </section>

  <section class="r-sect" style="max-width:1220px; margin:0 auto; padding:0 32px 24px;">
    <div style="height:360px; border-radius:10px; overflow:hidden; background:linear-gradient(135deg,#E2DCE2,#dde8e2); display:flex; align-items:center; justify-content:center; text-align:center; padding:32px;">
      <div>
        <div style="font-family:'Fraunces',serif; font-size:clamp(30px,4vw,48px); color:#483E5E; margin-bottom:12px;">Family wellness for the Clark area.</div>
        <a href={contactInfo.mapsUrl} style="color:#608F84; font-weight:700; text-decoration:none;">Open in Google Maps&nbsp;→</a>
      </div>
    </div>
  </section>

  <section class="r-sect r-pad-lg" style="max-width:1220px; margin:0 auto; padding:80px 32px 96px;">
    <div style="max-width:34em; margin-bottom:36px;">
      <div style="font-size:12.5px; font-weight:600; letter-spacing:.16em; text-transform:uppercase; color:#608F84; margin-bottom:18px;">Serving nearby families</div>
      <h2 style="font-family:'Fraunces',serif; font-weight:400; font-size:clamp(32px,4.2vw,52px); line-height:1.08; color:#483E5E; margin:0;">Just off the Parkway.</h2>
    </div>
    <div class="r-towns" style="display:grid; grid-template-columns:repeat(4,1fr); gap:16px;">
      {towns.map((town) => (
        <div style="background:#FCF0DD; border:1px solid rgba(72,62,94,.12); border-radius:8px; padding:24px 22px; font-family:'Fraunces',serif; font-size:20px; color:#483E5E;">{town}</div>
      ))}
    </div>
  </section>

  <section class="r-sect r-pad-lg" style="background:#483E5E; color:#FCF0DD; padding:100px 32px;">
    <div style="max-width:760px; margin:0 auto; text-align:center;">
      <h2 style="font-family:'Fraunces',serif; font-weight:400; font-size:clamp(34px,4.6vw,58px); line-height:1.08; color:#FCF0DD; margin:0 0 26px;">Prefer to start with a conversation?</h2>
      <p style="font-size:18px; line-height:1.65; color:#d6cfe0; max-width:32em; margin:0 auto 38px;">Come tell us what is going on. We will be straight with you about whether we can help and what it would take: no pressure, no hard sell.</p>
      <div style="display:flex; gap:18px; justify-content:center; flex-wrap:wrap;">
        <a class="h-btn-primary" href={bookingUrl} style="text-decoration:none; background:#EBA040; color:#483E5E; font-weight:700; font-size:17px; padding:18px 40px; border-radius:999px; display:inline-block; box-shadow:0 6px 22px rgba(235,160,64,.32);">Book a visit</a>
        <a href="/2patient-resources/" style="text-decoration:none; color:#FCF0DD; font-weight:700; font-size:17px; padding:17px 36px; border-radius:999px; display:inline-block; border:1.5px solid rgba(252,240,221,.35);">Read Start Here&nbsp;→</a>
      </div>
    </div>
  </section>
</DraftReferenceLayout>
