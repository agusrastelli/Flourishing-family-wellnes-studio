---
import DraftReferenceLayout from '../../layouts/DraftReferenceLayout.astro';
import SocialLinks from '../../components/SocialLinks.astro';
---

<DraftReferenceLayout title="Contact" description="Contact Flourishing Family Wellness Studio." current="contact">
  <!-- ===== HERO + CONTACT DETAILS ===== -->
  <section class="r-contact r-sect" style="max-width:1220px; margin:0 auto; padding:74px 32px 88px; display:grid; grid-template-columns:1fr 1fr; gap:64px; align-items:start;">
    <div>
      <div style="display:inline-flex; align-items:center; gap:9px; font-size:12.5px; font-weight:600; letter-spacing:.16em; text-transform:uppercase; color:#608F84; margin-bottom:34px;">
        <span style="width:22px; height:1.5px; background:#608F84; display:inline-block;"></span>
        Contact &amp; visit
      </div>
      <h1 style="font-family:'Fraunces',serif; font-weight:400; font-size:clamp(44px,6vw,80px); line-height:1.03; letter-spacing:-.02em; color:#483E5E; margin:0 0 26px;">Prefer to talk<br />to a person first?</h1>
      <p style="font-size:20px; line-height:1.62; color:#194247; max-width:30em; margin:0 0 34px; opacity:.92;">That is completely fine. Book online if you are ready, or call the studio and we will help you figure out the right next step.</p>
      <div style="display:flex; gap:16px; flex-wrap:wrap;">
        <a class="h-btn-primary" href="tel:+19086530000" style="text-decoration:none; background:#EBA040; color:#483E5E; font-weight:700; font-size:17px; padding:18px 36px; border-radius:999px; box-shadow:0 6px 22px rgba(235,160,64,.32);">Call the studio</a>
        <a class="h-link-underline" href="https://portal.sked.life" style="text-decoration:none; color:#483E5E; font-weight:600; font-size:16px; border-bottom:2px solid rgba(72,62,94,.25); padding-bottom:3px; align-self:center;">Book online&nbsp;→</a>
      </div>
    </div>

    <div style="display:flex; flex-direction:column; gap:16px;">
      <div style="background:#FCF0DD; border:1px solid rgba(72,62,94,.12); border-radius:10px; padding:26px 28px; display:flex; gap:16px; align-items:flex-start; box-shadow:0 10px 30px -22px rgba(72,62,94,.4);">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#608F84" stroke-width="1.7" style="flex:none; margin-top:2px;"><path d="M12 21s-7-5.2-7-11a7 7 0 0114 0c0 5.8-7 11-7 11z"></path><circle cx="12" cy="10" r="2.5"></circle></svg>
        <div>
          <div style="font-size:12px; font-weight:700; letter-spacing:.12em; text-transform:uppercase; color:#B7863E; margin-bottom:6px;">Studio</div>
          <div style="font-size:17px; line-height:1.5; color:#483E5E; font-weight:600;">68 Washington Street</div>
          <div style="font-size:16px; line-height:1.5; color:#194247; opacity:.85;">Clark, NJ 07066</div>
        </div>
      </div>
      <div style="background:#FCF0DD; border:1px solid rgba(72,62,94,.12); border-radius:10px; padding:26px 28px; display:flex; gap:16px; align-items:flex-start; box-shadow:0 10px 30px -22px rgba(72,62,94,.4);">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#608F84" stroke-width="1.7" style="flex:none; margin-top:2px;"><path d="M5 4h4l2 5-2.5 1.5a11 11 0 005 5L20 13l1 4v2a1 1 0 01-1 1A16 16 0 014 5a1 1 0 011-1z"></path></svg>
        <div>
          <div style="font-size:12px; font-weight:700; letter-spacing:.12em; text-transform:uppercase; color:#B7863E; margin-bottom:6px;">Call or text</div>
          <a href="tel:+19086530000" style="font-size:17px; line-height:1.5; color:#483E5E; font-weight:600; text-decoration:none;">(908) 653-0000</a>
        </div>
      </div>
      <div class="contact-social-card">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#608F84" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" style="flex:none; margin-top:2px;">
          <path d="M20.8 8.6c0 5.2-8.8 10.1-8.8 10.1S3.2 13.8 3.2 8.6A4.6 4.6 0 0112 6.4a4.6 4.6 0 018.8 2.2z"></path>
        </svg>
        <div>
          <div class="contact-social-eyebrow">Follow along</div>
          <SocialLinks />
        </div>
      </div>
      <div style="background:#FCF0DD; border:1px solid rgba(72,62,94,.12); border-radius:10px; padding:26px 28px; display:flex; gap:16px; align-items:flex-start; box-shadow:0 10px 30px -22px rgba(72,62,94,.4);">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#608F84" stroke-width="1.7" style="flex:none; margin-top:2px;"><circle cx="12" cy="12" r="9"></circle><path d="M12 7v5l3 2"></path></svg>
        <div style="flex:1;">
          <div style="font-size:12px; font-weight:700; letter-spacing:.12em; text-transform:uppercase; color:#B7863E; margin-bottom:10px;">Hours</div>
          <div style="display:flex; justify-content:space-between; gap:16px; font-size:15.5px; color:#194247; padding:3px 0;"><span>Mon</span><span style="color:#483E5E; font-weight:600;">9:00a – 1:00p &amp; 3:00p – 7:00p</span></div>
          <div style="display:flex; justify-content:space-between; gap:16px; font-size:15.5px; color:#194247; opacity:.6; padding:3px 0;"><span>Tue</span><span>Closed</span></div>
          <div style="display:flex; justify-content:space-between; gap:16px; font-size:15.5px; color:#194247; padding:3px 0;"><span>Wed</span><span style="color:#483E5E; font-weight:600;">3:00p – 6:30p</span></div>
          <div style="display:flex; justify-content:space-between; gap:16px; font-size:15.5px; color:#194247; padding:3px 0;"><span>Thu</span><span style="color:#483E5E; font-weight:600;">9:00a – 1:00p &amp; 3:00p – 6:00p</span></div>
          <div style="display:flex; justify-content:space-between; gap:16px; font-size:15.5px; color:#194247; padding:3px 0;"><span>Fri</span><span style="color:#483E5E; font-weight:600;">8:00a – 12:00p</span></div>
          <div style="display:flex; justify-content:space-between; gap:16px; font-size:15.5px; color:#194247; padding:3px 0;"><span>Sat</span><span style="color:#483E5E; font-weight:600;">8:00a – 11:30a</span></div>
          <div style="display:flex; justify-content:space-between; gap:16px; font-size:15.5px; color:#194247; opacity:.6; padding:3px 0;"><span>Sun</span><span>Closed</span></div>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== MAP / LOCATION BAND ===== -->
  <section class="r-sect" style="max-width:1220px; margin:0 auto; padding:0 32px 24px;">
    <div class="contact-map-frame">
      <iframe
        title="Map to Flourishing Family Wellness Studio"
        src="https://maps.google.com/maps?q=68%20Washington%20Street%2C%20Clark%2C%20NJ%2007066&t=m&z=14&output=embed&iwloc=near"
        width="600"
        height="450"
        allowfullscreen
        loading="eager"
        referrerpolicy="no-referrer-when-downgrade"
      ></iframe>
      <a class="contact-map-fallback h-link-underline" href="https://www.google.com/maps/search/?api=1&query=68%20Washington%20Street%2C%20Clark%2C%20NJ%2007066" target="_blank" rel="noopener noreferrer">
        Open in Google Maps&nbsp;→
      </a>
    </div>
  </section>

  <!-- ===== SERVICE AREA ===== -->
  <section class="r-sect r-pad-lg" style="max-width:1220px; margin:0 auto; padding:80px 32px 96px;">
    <div style="max-width:36em; margin-bottom:40px;">
      <div style="font-size:12.5px; font-weight:600; letter-spacing:.16em; text-transform:uppercase; color:#608F84; margin-bottom:18px;">Who we serve</div>
      <h2 style="font-family:'Fraunces',serif; font-weight:400; font-size:clamp(30px,4vw,48px); line-height:1.08; letter-spacing:-.015em; color:#483E5E; margin:0 0 16px;">Family wellness for the Clark area.</h2>
      <p style="font-size:18px; line-height:1.6; color:#194247; opacity:.88; margin:0;">Just off the Parkway and easy to reach from across Union County.</p>
    </div>
    <div class="r-towns" style="display:grid; grid-template-columns:repeat(4,1fr); gap:16px;">
      <div style="background:#E2DCE2; border-radius:8px; padding:26px 24px; text-align:center;">
        <div style="font-family:'Fraunces',serif; font-size:22px; color:#483E5E;">Clark</div>
        <div style="font-size:13px; color:#608F84; font-weight:600; margin-top:4px;">Home base</div>
      </div>
      <div style="background:#E2DCE2; border-radius:8px; padding:26px 24px; text-align:center;">
        <div style="font-family:'Fraunces',serif; font-size:22px; color:#483E5E;">Westfield</div>
        <div style="font-size:13px; color:#608F84; font-weight:600; margin-top:4px;">~10 min</div>
      </div>
      <div style="background:#E2DCE2; border-radius:8px; padding:26px 24px; text-align:center;">
        <div style="font-family:'Fraunces',serif; font-size:22px; color:#483E5E;">Scotch Plains</div>
        <div style="font-size:13px; color:#608F84; font-weight:600; margin-top:4px;">~12 min</div>
      </div>
      <div style="background:#E2DCE2; border-radius:8px; padding:26px 24px; text-align:center;">
        <div style="font-family:'Fraunces',serif; font-size:22px; color:#483E5E;">Cranford</div>
        <div style="font-size:13px; color:#608F84; font-weight:600; margin-top:4px;">~8 min</div>
      </div>
    </div>
  </section>

</DraftReferenceLayout>
