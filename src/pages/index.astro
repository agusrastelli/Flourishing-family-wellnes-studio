            </div>
          </div>
        </div>
      </div>

      <div style="border-top:1px solid rgba(252,240,221,.16); padding:30px 0 40px; max-width:1220px; margin:0 auto; display:flex; justify-content:space-between; align-items:center; gap:20px; flex-wrap:wrap;">
        <div style="display:flex; align-items:center; gap:14px;">
          <span style="width:48px; height:48px; border-radius:50%; background:#FCF0DD; display:flex; align-items:center; justify-content:center; flex:none;"></span>
          <span style="display:flex; flex-direction:column; line-height:1;">
            <span style="font-family:'Fraunces',serif; font-weight:500; font-size:20px; color:#FCF0DD;">Flourishing&nbsp;Family</span>
            <span style="font-size:10px; letter-spacing:.28em; text-transform:uppercase; color:#608F84; margin-top:5px; font-weight:600;">Wellness Studio · Clark, NJ</span>
          </span>
