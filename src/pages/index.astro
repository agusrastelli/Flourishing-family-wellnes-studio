---
import { Image } from 'astro:assets';
import MeetDoctors from '../components/MeetDoctors.astro';
import ProofBand from '../components/ProofBand.astro';
import ProgramCards from '../components/ProgramCards.astro';
import Layout from '../layouts/InternalLayout.astro';
import heroImage from '../../assets/opt/hero.jpg';
import ilaImage from '../../assets/opt/ila.jpg';

type TestimonialTreatment = 'Deep Plum' | 'Sage Teal';

interface Props {
  announcementBar?: boolean;
  stickyBookButton?: boolean;
  testimonialTreatment?: TestimonialTreatment;
}

const {
  announcementBar = true,
  stickyBookButton = true,
  testimonialTreatment = 'Deep Plum',
} = Astro.props;

---

<Layout>

    <!-- ===== HERO ===== -->
    <section id="top" class="r-hero r-sect" style="max-width:1220px; margin:0 auto; padding:72px 32px 84px; display:grid; grid-template-columns:1.05fr .95fr; gap:64px; align-items:center;">
      <div>
        <div style="display:inline-flex; align-items:center; gap:9px; font-size:12.5px; font-weight:600; letter-spacing:.16em; text-transform:uppercase; color:#608F84; margin-bottom:38px;">
          <span style="width:22px; height:1.5px; background:#608F84; display:inline-block;"></span>
          Fertility · Pregnancy · Postpartum · Family
        </div>
        <h1 style="font-family:'Fraunces',serif; font-weight:400; font-size:clamp(48px,6.4vw,92px); line-height:1.02; letter-spacing:-.02em; color:#483E5E; margin:0 0 26px;">Feel like<br />yourself again.</h1>
        <p style="font-size:20px; line-height:1.65; color:#194247; max-width:30em; margin:0 0 36px; opacity:.92;">You know your body better than anyone keeps telling you. We're the doctors who actually listen — through trying, expecting, recovering, and every ordinary day in between. One-on-one, start to finish.</p>
        <div style="display:flex; align-items:center; gap:26px; flex-wrap:wrap;">
          <a href="/resources/start-here/" class="h-btn-primary" style="text-decoration:none; background:#EBA040; color:#483E5E; font-weight:700; font-size:17px; padding:18px 38px; border-radius:999px; box-shadow:0 6px 22px rgba(235,160,64,.32);">Start Here</a>
          <a href="#book" class="h-link-underline" style="text-decoration:none; color:#483E5E; font-weight:600; font-size:16px; border-bottom:2px solid rgba(72,62,94,.25); padding-bottom:3px;">or just book a visit&nbsp;→</a>
        </div>
        <div style="margin-top:40px; font-size:14.5px; color:#194247; opacity:.78; letter-spacing:.01em;">Trusted by Clark-area families since 2011.</div>
      </div>

      <div style="position:relative; aspect-ratio:4/5; border-radius:6px; overflow:hidden; background:#ece0d6; box-shadow:0 30px 60px -28px rgba(72,62,94,.4);">
        <Image src={heroImage} alt="A Flourishing Family doctor talking through pelvic care with a patient in natural light" widths={[420, 640, 820, 1040, 1280]} sizes="(max-width: 940px) calc(100vw - 56px), 46vw" format="webp" quality="high" priority loading="eager" decoding="async" style="position:absolute; inset:0; width:100%; height:100%; object-fit:cover; display:block;" />
      </div>
    </section>

    <!-- ===== THE JOURNEYS ===== -->
    <section id="journeys" class="r-sect r-pad-lg" style="background:#E2DCE2; padding:96px 32px;">
      <div style="max-width:1220px; margin:0 auto;">
        <div style="max-width:34em; margin-bottom:56px;">
          <div style="font-size:12.5px; font-weight:600; letter-spacing:.16em; text-transform:uppercase; color:#608F84; margin-bottom:18px;">Wherever you are right now</div>
          <h2 style="font-family:'Fraunces',serif; font-weight:400; font-size:clamp(34px,4.4vw,56px); line-height:1.06; letter-spacing:-.015em; color:#483E5E; margin:0 0 20px;">Four journeys. One practice that grows with you.</h2>
          <p style="font-size:18px; line-height:1.6; color:#194247; opacity:.88; margin:0;">Most families find us for one thing — and stay for the rest of life. That's not an accident.</p>
        </div>

        <ProgramCards />
      </div>
    </section>

    <!-- ===== WHY DIFFERENT ===== -->
    <section id="services" class="r-split r-sect r-pad-lg" style="max-width:1220px; margin:0 auto; padding:104px 32px; display:grid; grid-template-columns:.92fr 1.08fr; gap:72px; align-items:center;">
      <div class="r-portrait" style="position:relative; aspect-ratio:5/6; border-radius:6px; overflow:hidden; background:linear-gradient(155deg,#dde8e2 0%,#ece0d6 60%,#f5e8d1 100%); box-shadow:0 28px 56px -30px rgba(72,62,94,.42);">
        <Image src={ilaImage} alt="Dr. Ila adjusting a patient — unhurried, hands-on, present" widths={[360, 540, 720, 900]} sizes="(max-width: 940px) calc(100vw - 84px), 39vw" format="webp" quality="high" loading="lazy" decoding="async" style="position:absolute; inset:14px; width:calc(100% - 28px); height:calc(100% - 28px); object-fit:cover; border-radius:3px; display:block;" />
      </div>
      <div>
        <div style="font-size:12.5px; font-weight:600; letter-spacing:.16em; text-transform:uppercase; color:#608F84; margin-bottom:20px;">What makes us different</div>
        <h2 style="font-family:'Fraunces',serif; font-weight:400; font-size:clamp(32px,4.1vw,52px); line-height:1.08; letter-spacing:-.015em; color:#483E5E; margin:0 0 26px;">It's just you and a doctor. Every single visit.</h2>
        <p style="font-size:18.5px; line-height:1.68; color:#194247; max-width:32em; margin:0 0 22px; opacity:.92;">No physician's assistants. No students practicing on you. The doctor who meets you is the doctor who treats you — the one who learns your history, explains the why, and remembers it next time. As one patient put it, we're "not just chiropractors — so much more."</p>
        <p style="font-family:'Fraunces',serif; font-style:italic; font-weight:500; font-size:17px; line-height:1.5; color:#608F84; max-width:26em; margin:0 0 30px;">"If you get your tires rotated more often than your nervous system gets regulated, we should talk."</p>
        <div class="r-twocol" style="display:flex; gap:36px; flex-wrap:nowrap; padding-top:26px; border-top:1px solid rgba(72,62,94,.12);">
          <div style="flex:1 1 0; min-width:0;">
            <div style="font-family:'Fraunces',serif; font-size:34px; color:#483E5E; line-height:1;">Thorough</div>
            <div style="font-size:14px; color:#608F84; font-weight:600; margin-top:8px; letter-spacing:.04em;">We measure, we track, we explain every step — so you're never just told to trust us.</div>
          </div>
          <div style="flex:1 1 0; min-width:0;">
            <div style="font-family:'Fraunces',serif; font-size:34px; color:#483E5E; line-height:1;">Patient</div>
            <div style="font-size:14px; color:#608F84; font-weight:600; margin-top:8px; letter-spacing:.04em;">Real change is a relationship, not a single visit. We're in it for the long run.</div>
          </div>
        </div>
      </div>
    </section>

    <ProofBand
      treatment={testimonialTreatment}
      quote="They support you like family — and they're the best chiropractor I've seen in twenty years."
      source="A Flourishing Family patient, Westfield"
    />

    <!-- ===== MEET THE DOCTORS ===== -->
    <MeetDoctors
      id="doctors"
      titleHtml="The people you'll<br />actually see."
      text="Same faces every time. The doctor you meet on day one is the one who's still with you a year later."
      linkHref="/about/"
    />

    <!-- ===== START HERE ===== -->
     <!--<section id="start" class="r-sect r-pad-lg" style="background:#E2DCE2; padding:104px 32px;">
      <div style="max-width:760px; margin:0 auto; text-align:center;">
        <div style="font-size:12.5px; font-weight:600; letter-spacing:.16em; text-transform:uppercase; color:#608F84; margin-bottom:22px;">Not sure where to begin?</div>
        <h2 style="font-family:'Fraunces',serif; font-weight:400; font-size:clamp(34px,4.6vw,58px); line-height:1.08; letter-spacing:-.015em; color:#483E5E; margin:0 0 26px;">Start with a conversation, not a commitment.</h2>
        <p style="font-size:19px; line-height:1.65; color:#194247; opacity:.9; max-width:30em; margin:0 auto 40px;">Come tell us what's going on — the achiness, the rough nights, the thing a few doctors already brushed off. We'll be straight with you about whether we can help and what it would really take. No pressure, no hard sell. Just a plan that fits your life and a doctor who'll remember your name next time you walk in.</p>
        <a href="/resources/start-here/" class="h-btn-primary" style="text-decoration:none; background:#EBA040; color:#483E5E; font-weight:700; font-size:17px; padding:18px 40px; border-radius:999px; box-shadow:0 6px 22px rgba(235,160,64,.32); display:inline-block;">Start Here</a>
      </div>
    </section>-->

