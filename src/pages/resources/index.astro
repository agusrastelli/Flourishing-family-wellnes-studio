---
import DraftReferenceLayout from '../../layouts/DraftReferenceLayout.astro';
import { bookingUrl } from '../../data/site';

const steps = [
  { title: 'A real conversation', text: 'We start by listening: your history, your goals, the things others brushed off. One-on-one with a doctor, always.' },
  { title: 'A thorough assessment', text: 'We find what is actually going on and build a plan around you: measurable and explained, never generic.' },
  { title: 'Care over time', text: 'Progress reviews and adjustments as your body changes, with the same doctor who started with you.' },
];

const prices = [
  ['Initial visit', 'Confirmed by visit type'],
  ['Chiropractic reference', '$65/session working guide'],
  ['Acupuncture reference', '$125/session working guide'],
  ['Programs', 'Confirmed at assessment'],
];

const testimonials = [
  'They support you like family, and they are the best chiropractor I have seen in twenty years.',
  'Not just chiropractors: so much more. They actually listened when no one else would.',
  'My whole family goes now. One place that knows all of us by name: it is rare.',
];

const guides = [
  { title: 'Preparing your body 3 months before trying', text: 'A practical guide to the preconception window: coming soon.', href: '/2fertility-journey/' },
  { title: 'Is chiropractic safe during pregnancy?', text: 'What Webster-certified care really looks like: coming soon.', href: '/2pregnancy-journey/' },
  { title: 'Why we adjust the nervous system, not just the back', text: 'The longevity philosophy, explained: coming soon.', href: '/2chiropractic/' },
];
---

<DraftReferenceLayout title="Patient Resources" description="What to expect, pricing, and resources." current="resources">
  <section class="r-hero r-sect" style="max-width:1220px; margin:0 auto; padding:74px 32px 80px; display:grid; grid-template-columns:1.05fr .95fr; gap:64px; align-items:center;">
    <div>
      <div style="display:inline-flex; align-items:center; gap:9px; font-size:12.5px; font-weight:600; letter-spacing:.16em; text-transform:uppercase; color:#608F84; margin-bottom:34px;">
        <span style="width:22px; height:1.5px; background:#608F84; display:inline-block;"></span>
        New here?
      </div>
      <h1 style="font-family:'Fraunces',serif; font-weight:400; font-size:clamp(44px,6vw,84px); line-height:1.03; letter-spacing:-.02em; color:#483E5E; margin:0 0 26px;">What to expect, before you book.</h1>
      <p style="font-size:20px; line-height:1.62; color:#194247; max-width:31em; margin:0 0 36px; opacity:.92;">What to expect, what it costs, and how long this really takes: answered up front, before you ever pick up the phone. No surprises, no runaround.</p>
      <div style="display:flex; align-items:center; gap:26px; flex-wrap:wrap;">
        <a class="h-btn-primary" href="#firstvisit" style="text-decoration:none; background:#EBA040; color:#483E5E; font-weight:700; font-size:17px; padding:18px 36px; border-radius:999px; box-shadow:0 6px 22px rgba(235,160,64,.32);">What to expect</a>
        <a class="h-link-underline" href="#pricing" style="text-decoration:none; color:#483E5E; font-weight:600; font-size:16px; border-bottom:2px solid rgba(72,62,94,.25); padding-bottom:3px;">Insurance & pricing&nbsp;→</a>
      </div>
    </div>
    <div style="aspect-ratio:4/5; background:linear-gradient(155deg,#dde8e2,#ece0d6); border-radius:8px; box-shadow:0 30px 60px -28px rgba(72,62,94,.4); overflow:hidden; position:relative;">
      <img src="/assets/opt/card-family.jpg" alt="A family wellness visit" style="position:absolute; inset:0; width:100%; height:100%; object-fit:cover; display:block;" />
    </div>
  </section>

  <section id="firstvisit" class="r-sect r-pad-lg" style="background:#E2DCE2; padding:96px 32px;">
    <div style="max-width:1220px; margin:0 auto;">
      <div style="max-width:36em; margin-bottom:52px;">
        <div style="font-size:12.5px; font-weight:600; letter-spacing:.16em; text-transform:uppercase; color:#608F84; margin-bottom:18px;">Your first visit</div>
        <h2 style="font-family:'Fraunces',serif; font-weight:400; font-size:clamp(32px,4.2vw,52px); line-height:1.08; color:#483E5E; margin:0 0 20px;">Your first visit, and the road after it.</h2>
        <p style="font-size:18px; line-height:1.6; color:#194247; opacity:.88; margin:0;">This is not a quick-fix, one-and-done kind of place. Real change is a relationship: here is how it unfolds.</p>
      </div>
      <div class="r-grid3" style="display:grid; grid-template-columns:repeat(3,1fr); gap:24px;">
        {steps.map((step, index) => (
          <div style="background:#FCF0DD; border-radius:8px; padding:32px 30px; box-shadow:0 8px 26px -18px rgba(72,62,94,.4);">
            <div style="font-family:'Fraunces',serif; font-size:34px; color:#EBA040; line-height:1; margin-bottom:16px;">0{index + 1}</div>
            <h3 style="font-family:'Fraunces',serif; font-size:22px; color:#483E5E; margin:0 0 10px;">{step.title}</h3>
            <p style="font-size:15.5px; line-height:1.58; color:#194247; opacity:.85; margin:0;">{step.text}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section id="pricing" class="r-price r-sect r-pad-lg" style="max-width:1220px; margin:0 auto; padding:100px 32px; display:grid; grid-template-columns:1fr 1fr; gap:64px; align-items:start;">
    <div>
      <div style="font-size:12.5px; font-weight:600; letter-spacing:.16em; text-transform:uppercase; color:#608F84; margin-bottom:18px;">Insurance & pricing</div>
      <h2 style="font-family:'Fraunces',serif; font-weight:400; font-size:clamp(32px,4.2vw,52px); line-height:1.08; color:#483E5E; margin:0 0 22px;">Clear pricing, before the objection.</h2>
      <p style="font-size:18px; line-height:1.66; color:#194247; opacity:.9; margin:0 0 22px;">We keep money out of the shadows. You will know what things cost, what your options are, and exactly what you are paying for, so the decision is about fit, not fine print.</p>
      <p style="font-family:'Fraunces',serif; font-style:italic; font-size:22px; line-height:1.4; color:#483E5E; margin:0;">Meaningful, lasting change takes time. We would rather tell you that up front than oversell a single visit.</p>
    </div>
    <div style="background:#FCF0DD; border-radius:12px; padding:34px 34px; box-shadow:0 20px 44px -24px rgba(72,62,94,.45);">
      {prices.map(([label, value], index) => (
        <div style={`display:flex; justify-content:space-between; gap:20px; align-items:baseline; padding:18px 0; ${index < prices.length - 1 ? 'border-bottom:1px solid rgba(72,62,94,.12);' : ''}`}>
          <div style="font-size:16px; color:#194247;">{label}</div>
          <div style="font-family:'Fraunces',serif; font-size:20px; color:#483E5E; text-align:right;">{value}</div>
        </div>
      ))}
      <p style="font-size:14.5px; line-height:1.55; color:#194247; opacity:.75; margin:22px 0 0;">Figures are current program guides and confirmed at your assessment. Acupuncture is never discounted.</p>
    </div>
  </section>

  <section class="r-sect r-pad-lg" style="background:#483E5E; color:#FCF0DD; padding:100px 32px;">
    <div style="max-width:1220px; margin:0 auto;">
      <div style="max-width:34em; margin-bottom:44px;">
        <div style="font-size:12.5px; font-weight:600; letter-spacing:.16em; text-transform:uppercase; color:#EBA040; margin-bottom:18px;">In their words</div>
        <h2 style="font-family:'Fraunces',serif; font-weight:400; font-size:clamp(32px,4.2vw,52px); line-height:1.08; color:#FCF0DD; margin:0;">Patients say the useful part.</h2>
      </div>
      <div class="r-grid3" style="display:grid; grid-template-columns:repeat(3,1fr); gap:24px;">
        {testimonials.map((quote) => (
          <blockquote style="background:rgba(252,240,221,.06); border:1px solid rgba(252,240,221,.14); border-radius:10px; padding:28px 28px; margin:0; font-family:'Fraunces',serif; font-size:22px; line-height:1.32; color:#FCF0DD;">"{quote}"</blockquote>
        ))}
      </div>
    </div>
  </section>

  <section class="r-sect r-pad-lg" style="max-width:1220px; margin:0 auto; padding:100px 32px;">
    <div style="max-width:34em; margin-bottom:44px;">
      <div style="font-size:12.5px; font-weight:600; letter-spacing:.16em; text-transform:uppercase; color:#608F84; margin-bottom:18px;">Notes & guides</div>
      <h2 style="font-family:'Fraunces',serif; font-weight:400; font-size:clamp(32px,4.2vw,52px); line-height:1.08; color:#483E5E; margin:0;">Coming soon.</h2>
    </div>
    <div class="r-grid3" style="display:grid; grid-template-columns:repeat(3,1fr); gap:24px;">
      {guides.map((guide) => (
        <a href={guide.href} style="text-decoration:none; background:#FCF0DD; border:1px solid rgba(72,62,94,.12); border-radius:8px; padding:28px 26px; display:block;">
          <h3 style="font-family:'Fraunces',serif; font-size:22px; color:#483E5E; margin:0 0 10px;">{guide.title}</h3>
          <p style="font-size:15px; line-height:1.55; color:#194247; opacity:.85; margin:0;">{guide.text}</p>
        </a>
      ))}
    </div>
  </section>

  <section class="r-sect r-pad-lg" style="background:#E2DCE2; padding:104px 32px;">
    <div style="max-width:760px; margin:0 auto; text-align:center;">
      <h2 style="font-family:'Fraunces',serif; font-weight:400; font-size:clamp(34px,4.6vw,58px); line-height:1.08; color:#483E5E; margin:0 0 26px;">Know what to expect? Let us begin.</h2>
      <p style="font-size:19px; line-height:1.65; color:#194247; opacity:.9; max-width:30em; margin:0 auto 40px;">Book your first visit, or start with a no-pressure conversation about whether we are the right fit.</p>
      <div style="display:flex; gap:20px; justify-content:center; flex-wrap:wrap;">
        <a class="h-btn-primary" href={bookingUrl} style="text-decoration:none; background:#EBA040; color:#483E5E; font-weight:700; font-size:17px; padding:18px 40px; border-radius:999px; display:inline-block; box-shadow:0 6px 22px rgba(235,160,64,.32);">Book your first visit</a>
        <a class="h-link-underline" href="/2contact/" style="text-decoration:none; color:#483E5E; font-weight:600; font-size:16px; border-bottom:2px solid rgba(72,62,94,.25); padding-bottom:3px; align-self:center;">Start with a conversation&nbsp;→</a>
      </div>
    </div>
  </section>
</DraftReferenceLayout>
